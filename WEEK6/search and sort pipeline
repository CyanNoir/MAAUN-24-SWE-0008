import random

# Step 1: Generate a list of 10 random candidate scores
scores = [random.randint(50, 100) for _ in range(10)]
print("Original Scores:", scores)


# Step 2: Recursive Merge Sort
def merge_sort(arr):
    if len(arr) <= 1:
        return arr

    mid = len(arr) // 2
    left = merge_sort(arr[:mid])
    right = merge_sort(arr[mid:])

    return merge(left, right)


def merge(left, right):
    sorted_list = []
    i = j = 0

    while i < len(left) and j < len(right):
        if left[i] < right[j]:
            sorted_list.append(left[i])
            i += 1
        else:
            sorted_list.append(right[j])
            j += 1

    sorted_list.extend(left[i:])
    sorted_list.extend(right[j:])
    return sorted_list


# Sort the scores
sorted_scores = merge_sort(scores)
print("Sorted Scores:", sorted_scores)


# Step 3: Binary Search
def binary_search(arr, target, left, right):
    if left > right:
        return -1

    mid = (left + right) // 2

    if arr[mid] == target:
        return mid
    elif target < arr[mid]:
        return binary_search(arr, target, left, mid - 1)
    else:
        return binary_search(arr, target, mid + 1, right)


# Step 4: Ask user for score
target_score = int(input("Enter the score you want to find: "))

rank = binary_search(sorted_scores, target_score, 0, len(sorted_scores) - 1)

if rank != -1:
    print("Candidate with score", target_score, "found at rank", rank)
else:
    print("Score not found in the list.")